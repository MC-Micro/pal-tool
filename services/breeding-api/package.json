{
  "name": "@pal-tool/breeding-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "tsx scripts/build-reference.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:worker": "wrangler deploy --dry-run --outdir dist",
    "validate": "tsx scripts/validate-reference.ts",
    "validate:release": "tsx scripts/validate-reference.ts --release",
    "check:deterministic": "tsx scripts/check-deterministic.ts",
    "scan:secrets": "tsx scripts/scan-secrets.ts",
    "ci": "pnpm generate && pnpm lint && pnpm typecheck && pnpm test && pnpm build:worker && pnpm validate && pnpm check:deterministic && pnpm scan:secrets",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "eslint": "latest",
    "tsx": "latest",
    "typescript": "5.9.3",
    "typescript-eslint": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0"
}
